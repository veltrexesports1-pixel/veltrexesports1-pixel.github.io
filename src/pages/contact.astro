---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact VeltRex Esports" description="Get in touch with VeltRex Esports for partnerships, tryouts, and business inquiries.">

  <section class="border-b border-white/10 px-4 py-14 sm:px-6 lg:px-12 lg:py-20">
    <div class="mx-auto max-w-7xl">
      <p class="mb-4 text-xs uppercase tracking-[0.3em] text-[#8624E5] sm:text-sm">Get In Touch</p>
      <h1 class="font-heading text-4xl font-black uppercase leading-[0.92] sm:text-6xl lg:text-7xl text-balance">Contact VeltRex Esports</h1>
    </div>
  </section>

  <section class="px-4 py-12 sm:px-6 lg:px-12 lg:py-16">
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[1fr_1.05fr]">
      <div class="space-y-10">
        <div>
          <h2 class="font-heading text-2xl font-black uppercase sm:text-3xl text-balance">Business Inquiries</h2>
          <p class="mt-5 max-w-xl text-sm leading-7 text-white/72 sm:text-base sm:leading-8">For Sponsorships, Brand Collaborations, Tournament Activations, Media Opportunities, And Esports Partnerships, Contact VeltRex Directly Through The Details Below.</p>
        </div>
        <div class="space-y-5 border border-white/10 bg-white/[0.03] p-6 sm:p-8">
          <div class="flex items-start gap-4">
            <div class="mt-1 text-[#8624E5]">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"></path><rect x="2" y="4" width="20" height="16" rx="2"></rect></svg>
            </div>
            <div>
              <p class="text-xs font-bold uppercase tracking-[0.18em] text-white/55">Partnership Email</p>
              <a href="mailto:partnership@veltrexesports.com" class="mt-2 block break-all text-sm font-semibold text-white transition hover:text-[#8624E5] sm:text-base">partnership@veltrexesports.com</a>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="mt-1 text-[#8624E5]">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path><rect width="20" height="14" x="2" y="6" rx="2"></rect></svg>
            </div>
            <div>
              <p class="text-xs font-bold uppercase tracking-[0.18em] text-white/55">Main Topics</p>
              <p class="mt-2 text-sm leading-7 text-white/75 sm:text-base">Sponsorships, Creator Campaigns, Tournament Opportunities, Brand Activations, And Strategic Partnerships.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="mt-1 text-[#8624E5]">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C5 4 6 3 6 3s1 1 1.5 1a2.5 2.5 0 0 1 0 5H6"></path><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5C18 4 17 3 17 3s-1 1-1.5 1a2.5 2.5 0 0 0 0 5H18"></path><path d="M4 22h16"></path><path d="M10 22V2h4v20"></path></svg>
            </div>
            <div>
              <p class="text-xs font-bold uppercase tracking-[0.18em] text-white/55">Esports &amp; Events</p>
              <p class="mt-2 text-sm leading-7 text-white/75 sm:text-base">Team Invitations, Tournament Participation, Competitive Opportunities, And Gaming Events.</p>
            </div>
          </div>
        </div>
        <div>
          <h3 class="font-heading text-2xl font-black uppercase sm:text-3xl text-balance">Social Channels</h3>
          <div class="mt-6 space-y-4">
            <a href="https://www.instagram.com/veltrex_esports/" target="_blank" rel="noreferrer" class="flex items-center gap-4 text-sm text-white/80 transition hover:text-[#8624E5] sm:text-base">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#8624E5]"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg>
              <span>Instagram: @veltrex_esports</span>
            </a>
            <a href="https://discord.gg/A6qDDKSdf" target="_blank" rel="noreferrer" class="flex items-center gap-4 text-sm text-white/80 transition hover:text-[#8624E5] sm:text-base">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#8624E5]"><path d="M2.992 16.342a2 2 0 0 1 .094 1.167l-1.065 3.29a1 1 0 0 0 1.236 1.168l3.413-.998a2 2 0 0 1 1.099.092 10 10 0 1 0-4.777-4.719"></path></svg>
              <span>Discord: veltrex-esports</span>
            </a>
            <a href="https://x.com/VeltrexEsp" target="_blank" rel="noreferrer" class="flex items-center gap-4 text-sm text-white/80 transition hover:text-[#8624E5] sm:text-base">
              <span class="w-[18px] text-center text-sm font-bold text-[#8624E5]">X</span>
              <span>X: @VeltrexEsp</span>
            </a>
            <a href="https://www.youtube.com/@Veltrexesports" target="_blank" rel="noreferrer" class="flex items-center gap-4 text-sm text-white/80 transition hover:text-[#8624E5] sm:text-base">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#8624E5]"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"></path><path d="m10 15 5-3-5-3z"></path></svg>
              <span>YouTube: @Veltrexesports</span>
            </a>
            <a href="https://kick.com/veltrexesports" target="_blank" rel="noreferrer" class="flex items-center gap-4 text-sm text-white/80 transition hover:text-[#8624E5] sm:text-base">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#8624E5]"><path d="M6 2h12l4 4v12l-4 4H6l-4-4V6l4-4z"/><path d="M10 8v8"/><path d="M14 8v8"/></svg>
              <span>Kick: @veltrexesports</span>
            </a>
            <a href="https://www.tiktok.com/@veltrexesports" target="_blank" rel="noreferrer" class="flex items-center gap-4 text-sm text-white/80 transition hover:text-[#8624E5] sm:text-base">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#8624E5]"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
              <span>TikTok: @veltrexesports</span>
            </a>
          </div>
        </div>
      </div>
      <div class="border border-white/10 bg-white/[0.03] p-6 sm:p-8">
        <h2 class="font-heading text-2xl font-black uppercase sm:text-3xl text-balance"><span class="text-[#8624E5]">Send</span> <span class="text-stroke-sm text-white">A</span> <span class="text-stroke-sm text-white">Message</span></h2>
        <p class="mt-4 text-sm leading-7 text-white/70 sm:text-base sm:leading-8">Use the form below to share your inquiry. For fastest response on Partnerships and Business Opportunities, Email Us Directly.</p>
        <form action="https://formsubmit.co/veltrexesports1@gmail.com" method="POST" class="mt-8 space-y-5">
          <input type="hidden" name="_subject" value="New Contact Form Submission" />
          <input type="hidden" name="_next" value="https://veltrexesports1-pixel.github.io/contact" />
          <input type="hidden" name="_captcha" value="false" />
          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label class="mb-3 block text-xs font-bold uppercase tracking-[0.18em] text-white/70">First Name</label>
              <input type="text" name="first_name" required class="w-full border border-white/10 bg-black px-4 py-4 text-white outline-none placeholder:text-white/30" placeholder="First Name" />
            </div>
            <div>
              <label class="mb-3 block text-xs font-bold uppercase tracking-[0.18em] text-white/70">Last Name</label>
              <input type="text" name="last_name" required class="w-full border border-white/10 bg-black px-4 py-4 text-white outline-none placeholder:text-white/30" placeholder="Last Name" />
            </div>
          </div>
          <div>
            <label class="mb-3 block text-xs font-bold uppercase tracking-[0.18em] text-white/70">Email Address</label>
            <input type="email" name="email" required class="w-full border border-white/10 bg-black px-4 py-4 text-white outline-none placeholder:text-white/30" placeholder="Your Email Address" />
          </div>
          <div>
            <label class="mb-3 block text-xs font-bold uppercase tracking-[0.18em] text-white/70">Choose A Topic</label>
            <select name="topic" class="w-full border border-white/10 bg-black px-4 py-4 text-white outline-none">
              <option selected>General Inquiry</option>
              <option>Partnership Opportunity</option>
              <option>Tournament Collaboration</option>
              <option>Creator Collaboration</option>
              <option>Media / Press</option>
            </select>
          </div>
          <div>
            <label class="mb-3 block text-xs font-bold uppercase tracking-[0.18em] text-white/70">Comments / Questions</label>
            <textarea rows="6" name="message" required class="w-full border border-white/10 bg-black px-4 py-4 text-white outline-none placeholder:text-white/30" placeholder="Tell Us More About Your Inquiry"></textarea>
          </div>
          <div class="border border-white/10 bg-black/40 p-4">
            <p class="text-xs uppercase tracking-[0.18em] text-white/60">Data Processing Consent</p>
            <label class="mt-3 flex items-start gap-3 text-sm leading-6 text-white/70">
              <input type="checkbox" name="consent" value="agreed" required class="mt-1" />
              <span>By sending this form, you agree with the storage and handling of your information for contact purposes.</span>
            </label>
          </div>
          <div class="flex flex-col gap-4 sm:flex-row">
            <button type="submit" class="inline-flex items-center justify-center gap-2 border border-[#8624E5] bg-[#8624E5] px-6 py-4 text-xs font-bold uppercase tracking-[0.2em] text-white transition hover:bg-transparent hover:text-[#8624E5] disabled:cursor-not-allowed disabled:opacity-60">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"></path><rect x="2" y="4" width="20" height="16" rx="2"></rect></svg>
              Send Message
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>

</Layout>
