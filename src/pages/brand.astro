---
import Layout from '../layouts/Layout.astro';
---

<Layout title="VeltRex Esports Brand Guidelines" description="Official brand guidelines and visual identity for VeltRex Esports.">

  <section class="border-b border-white/10 px-6 py-16 lg:px-12">
    <div class="mx-auto max-w-7xl text-center">
      <p class="mb-3 text-sm uppercase tracking-[0.3em] text-brand">identity</p>
      <h1 class="font-heading text-4xl font-black uppercase sm:text-6xl text-balance"><span class="text-[#8624E5]">Brand</span> <span class="text-stroke-sm text-white">Guidelines</span></h1>
      <p class="mx-auto mt-5 max-w-3xl text-white/65">VeltRex Esports visual identity, logo usage, colors, and typography.</p>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-6 py-20 lg:px-12">
    <div class="grid gap-10 md:grid-cols-2">
      <div class="border border-white/10 bg-white/[0.03] p-8">
        <h2 class="font-heading mb-4 text-lg font-black uppercase">Primary Logo</h2>
        <div class="flex h-32 w-32 items-center justify-center rounded bg-gradient-to-br from-brand to-[#06B6D4] text-5xl font-black text-white">V</div>
        <p class="mt-4 text-sm text-white/60">The VeltRex mark. Always use the official logo files provided in the assets folder. Do not stretch, recolor, or modify.</p>
      </div>
      <div class="border border-white/10 bg-white/[0.03] p-8">
        <h2 class="font-heading mb-4 text-lg font-black uppercase">Brand Color</h2>
        <div class="flex items-center gap-4"><div class="h-12 w-12 rounded bg-brand"></div><div><p class="font-mono text-sm text-white/80">#8624E5</p><p class="text-xs uppercase tracking-wider text-white/50">Violet / Primary</p></div></div>
        <div class="mt-4 flex items-center gap-4"><div class="h-12 w-12 rounded bg-[#06B6D4]"></div><div><p class="font-mono text-sm text-white/80">#06B6D4</p><p class="text-xs uppercase tracking-wider text-white/50">Cyan / Secondary</p></div></div>
      </div>
      <div class="border border-white/10 bg-white/[0.03] p-8 md:col-span-2">
        <h2 class="font-heading mb-4 text-lg font-black uppercase">Usage Guidelines</h2>
        <ul class="space-y-2 text-sm text-white/70">
          <li>• Always use the official logo with clear space equal to the height of the "V" mark.</li>
          <li>• Do not place the logo on busy backgrounds without sufficient contrast.</li>
          <li>• Preferred background colors: black (#070809), dark gray (#101114), or white for print.</li>
          <li>• The brand violet (#8624E5) should be used as the primary accent across all touchpoints.</li>
          <li>• For questions, contact brand@veltrexesports.com</li>
        </ul>
      </div>
    </div>
  </section>

</Layout>
