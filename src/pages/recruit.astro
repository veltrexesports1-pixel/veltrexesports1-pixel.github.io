---
import Layout from '../layouts/Layout.astro';
import openings from '../data/openings.json';
---

<Layout title="VeltRex Esports Recruitment | Tryouts Open" description="Join VeltRex Esports — tryout slots open for Valorant, League of Legends, and MLBB. Apply now.">

  <section class="border-b border-white/10 px-4 py-14 sm:px-6 lg:px-12 lg:py-20">
    <div class="mx-auto max-w-7xl">
      <p class="mb-4 text-xs uppercase tracking-[0.3em] text-[#8624E5] sm:text-sm">Join The Roster</p>
      <h1 class="font-heading text-4xl font-black uppercase leading-[0.92] sm:text-6xl lg:text-7xl text-balance">Recruitment &amp; Tryouts</h1>
      <p class="mt-6 max-w-2xl text-sm leading-7 text-white/70 sm:text-base sm:leading-8">VeltRex Esports is looking for dedicated players to compete in Valorant, League of Legends, and MLBB. If you have the drive and the skill, submit your application below.</p>
    </div>
  </section>

  <section class="px-4 py-12 sm:px-6 lg:px-12 lg:py-16">
    <div class="mx-auto max-w-7xl">
      <h2 class="font-heading text-3xl font-black uppercase sm:text-4xl text-balance">
        <span class="text-[#8624E5]">Open</span> <span class="text-stroke-sm text-white">Positions</span>
      </h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {openings.filter(o => o.status === 'open').map(opening => (
          <div class="border border-white/10 bg-white/[0.03] p-6 transition hover:border-[#8624E5]/30 sm:p-8">
            <div class="mb-4 flex items-start justify-between gap-4">
              <div>
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#8624E5]">{opening.game}</p>
                <h3 class="mt-2 font-heading text-2xl font-black uppercase">{opening.role}</h3>
              </div>
              <span class="shrink-0 rounded-full bg-green-500/15 px-3 py-1 text-[10px] font-bold uppercase tracking-[0.12em] text-green-400">Open</span>
            </div>
            <ul class="space-y-2 border-t border-white/10 pt-4">
              {opening.requirements.map(req => (
                <li class="flex items-start gap-3 text-sm text-white/75">
                  <svg class="mt-0.5 shrink-0 text-[#8624E5]" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
                  {req}
                </li>
              ))}
            </ul>
            <a href="#application-form" class="mt-6 inline-flex items-center justify-center gap-2 border border-[#8624E5] bg-[#8624E5] px-5 py-3 text-xs font-bold uppercase tracking-[0.2em] text-white transition hover:bg-transparent hover:text-[#8624E5] w-full text-center">
              Apply Now
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="application-form" class="border-t border-white/10 px-4 py-12 sm:px-6 lg:px-12 lg:py-16">
    <div class="mx-auto max-w-3xl">
      <h2 class="font-heading text-3xl font-black uppercase sm:text-4xl text-balance">
        <span class="text-[#8624E5]">Apply</span> <span class="text-stroke-sm text-white">Now</span>
      </h2>
      <p class="mt-4 text-sm leading-7 text-white/70 sm:text-base sm:leading-8">Fill out the form below and our recruitment team will review your application.</p>
      <form action="https://formsubmit.co/veltrexesports1@gmail.com" method="POST" class="mt-8 space-y-5">
        <input type="hidden" name="_subject" value="New Tryout Application" />
        <input type="hidden" name="_next" value="https://veltrexesports1-pixel.github.io/recruit" />
        <input type="hidden" name="_captcha" value="true" />
        <input type="text" name="_honey" style="display:none" />
        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <label class="mb-3 block text-xs font-bold uppercase tracking-[0.18em] text-white/70">Full Name *</label>
            <input type="text" name="full_name" required class="w-full border border-white/10 bg-black px-4 py-4 text-white outline-none placeholder:text-white/30" placeholder="Your Full Name" />
          </div>
          <div>
            <label class="mb-3 block text-xs font-bold uppercase tracking-[0.18em] text-white/70">Age *</label>
            <input type="number" name="age" required min="16" class="w-full border border-white/10 bg-black px-4 py-4 text-white outline-none placeholder:text-white/30" placeholder="Your Age" />
          </div>
        </div>
        <div>
          <label class="mb-3 block text-xs font-bold uppercase tracking-[0.18em] text-white/70">Game / Team *</label>
          <select name="game" required class="w-full border border-white/10 bg-black px-4 py-4 text-white outline-none">
            <option value="">Select a game...</option>
            <option>Valorant</option>
            <option>Valorant GC</option>
            <option>League of Legends</option>
            <option>MLBB Female</option>
          </select>
        </div>
        <div>
          <label class="mb-3 block text-xs font-bold uppercase tracking-[0.18em] text-white/70">Role Applying For *</label>
          <input type="text" name="role" required class="w-full border border-white/10 bg-black px-4 py-4 text-white outline-none placeholder:text-white/30" placeholder="e.g. Duelist, Mid Laner, Support" />
        </div>
        <div>
          <label class="mb-3 block text-xs font-bold uppercase tracking-[0.18em] text-white/70">Current Rank *</label>
          <input type="text" name="current_rank" required class="w-full border border-white/10 bg-black px-4 py-4 text-white outline-none placeholder:text-white/30" placeholder="e.g. Immortal 3, Diamond 2, Mythic Honor" />
        </div>
        <div>
          <label class="mb-3 block text-xs font-bold uppercase tracking-[0.18em] text-white/70">Discord Tag *</label>
          <input type="text" name="discord_tag" required class="w-full border border-white/10 bg-black px-4 py-4 text-white outline-none placeholder:text-white/30" placeholder="e.g. username#0000" />
        </div>
        <div>
          <label class="mb-3 block text-xs font-bold uppercase tracking-[0.18em] text-white/70">Previous Experience</label>
          <textarea rows="4" name="previous_experience" class="w-full border border-white/10 bg-black px-4 py-4 text-white outline-none placeholder:text-white/30" placeholder="Past teams, tournaments, or competitive background"></textarea>
        </div>
        <div>
          <label class="mb-3 block text-xs font-bold uppercase tracking-[0.18em] text-white/70">Why VeltRex?</label>
          <textarea rows="4" name="why_veltrex" class="w-full border border-white/10 bg-black px-4 py-4 text-white outline-none placeholder:text-white/30" placeholder="What makes you want to join VeltRex Esports?"></textarea>
        </div>
        <div>
          <label class="mb-3 block text-xs font-bold uppercase tracking-[0.18em] text-white/70">Link to VOD / Portfolio</label>
          <input type="url" name="vod_link" class="w-full border border-white/10 bg-black px-4 py-4 text-white outline-none placeholder:text-white/30" placeholder="https://..." />
        </div>
        <div class="border border-white/10 bg-black/40 p-4">
          <p class="text-xs uppercase tracking-[0.18em] text-white/60">Data Processing Consent</p>
          <label class="mt-3 flex items-start gap-3 text-sm leading-6 text-white/70">
            <input type="checkbox" name="consent" value="agreed" required class="mt-1" />
            <span>By sending this form, you agree with the storage and handling of your information for recruitment purposes.</span>
          </label>
        </div>
        <div class="flex flex-col gap-4 sm:flex-row">
          <button type="submit" class="inline-flex items-center justify-center gap-2 border border-[#8624E5] bg-[#8624E5] px-6 py-4 text-xs font-bold uppercase tracking-[0.2em] text-white transition hover:bg-transparent hover:text-[#8624E5] disabled:cursor-not-allowed disabled:opacity-60">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"></path><rect x="2" y="4" width="20" height="16" rx="2"></rect></svg>
            Submit Application
          </button>
        </div>
      </form>
    </div>
  </section>

</Layout>
