---
import Layout from '../layouts/Layout.astro';
---

<Layout title="VeltRex Esports Content Creators" description="Meet the VeltRex Esports content creator team.">

  <section class="border-b border-white/10 px-6 py-16 lg:px-12">
    <div class="mx-auto max-w-7xl text-center">
      <p class="mb-3 text-sm uppercase tracking-[0.3em] text-brand">content creators</p>
      <h1 class="font-heading text-4xl font-black uppercase sm:text-6xl text-balance"><span class="text-[#8624E5]">Our</span> <span class="text-stroke-sm text-white">Creators</span></h1>
      <p class="mx-auto mt-5 max-w-3xl text-white/65">Meet the VeltRex creator roster bringing esports content to life.</p>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-6 py-20 lg:px-12">
    <div class="mb-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      <div data-reveal data-reveal-delay="100" class="group relative overflow-hidden border border-white/10 bg-white/[0.03] text-center transition hover:border-brand/40 hover-tilt hover-glow"><img src="/assets/images/creator-5.jpg" alt="Creator photo" class="aspect-[3/4] w-full object-cover" /><div class="p-5"><h3 class="text-sm font-black uppercase tracking-wide">CallMeSylveon</h3><p class="mt-1 text-xs uppercase tracking-wider text-white/50">Valorant / Streamer</p></div></div>
      <div data-reveal data-reveal-delay="200" class="group relative overflow-hidden border border-white/10 bg-white/[0.03] text-center transition hover:border-brand/40 hover-tilt hover-glow"><img src="/assets/images/creator-6.jpg" alt="Creator photo" class="aspect-[3/4] w-full object-cover" /><div class="p-5"><h3 class="text-sm font-black uppercase tracking-wide">DarkNES</h3><p class="mt-1 text-xs uppercase tracking-wider text-white/50">League of Legends / Content</p></div></div>
      <div data-reveal data-reveal-delay="300" class="group relative overflow-hidden border border-white/10 bg-white/[0.03] text-center transition hover:border-brand/40 hover-tilt hover-glow"><img src="/assets/images/creator-7.jpg" alt="Creator photo" class="aspect-[3/4] w-full object-cover" /><div class="p-5"><h3 class="text-sm font-black uppercase tracking-wide">Zer0Gravity</h3><p class="mt-1 text-xs uppercase tracking-wider text-white/50">Fortnite / Streamer</p></div></div>
      <div data-reveal data-reveal-delay="400" class="group relative overflow-hidden border border-white/10 bg-white/[0.03] text-center transition hover:border-brand/40 hover-tilt hover-glow"><img src="/assets/images/creator-8.jpg" alt="Creator photo" class="aspect-[3/4] w-full object-cover" /><div class="p-5"><h3 class="text-sm font-black uppercase tracking-wide">PixelQueen</h3><p class="mt-1 text-xs uppercase tracking-wider text-white/50">MLBB / Content Creator</p></div></div>
    </div>
    <div class="text-center">
      <p class="text-sm text-white/50">More creators joining soon. Stay tuned.</p>
    </div>
  </section>

</Layout>
