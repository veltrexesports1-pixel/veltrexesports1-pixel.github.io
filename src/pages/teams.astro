---
import Layout from '../layouts/Layout.astro';
---

<Layout title="VeltRex Esports Teams | Valorant, League of Legends, MLBB" description="Meet VeltRex Esports competitive rosters across Valorant, Valorant Game Changers, League of Legends, and MLBB.">

  <section class="border-b border-white/10 px-6 py-16 lg:px-12">
    <div class="mx-auto max-w-7xl text-center">
      <p class="mb-3 text-sm uppercase tracking-[0.3em] text-[#8624E5]">veltrex squads</p>
      <h1 class="font-heading text-4xl font-black uppercase sm:text-6xl text-balance"><span class="text-[#8624E5]">meet</span> <span class="text-stroke-sm text-white">our squads</span></h1>
      <p class="mx-auto mt-5 max-w-3xl text-white/65">Explore our competitive rosters and discover the players behind VeltRex Esports.</p>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-6 py-20 lg:px-12">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      <a class="group block" href="/teams/valorant">
        <div class="relative overflow-hidden border border-white/10 bg-black">
          <div class="relative">
            <img src="/assets/images/game-valorant.jpg" alt="Valorant" class="h-auto w-full object-cover" style="aspect-ratio:900/1200" />
            <div class="absolute inset-0 bg-black/35 transition duration-300 group-hover:bg-black/60"></div>
            <div class="absolute inset-0 z-20 flex flex-col items-center justify-center px-6 text-center">
              <div class="transition-all duration-300 group-hover:-translate-y-6">
                <span class="text-3xl font-black uppercase tracking-[0.1em] text-white/80">VALORANT</span>
              </div>
              <div class="mt-6 translate-y-6 opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">
                <div class="flex flex-wrap items-center justify-center gap-x-2 gap-y-1 text-sm font-semibold text-white/90">
                  <span>Nelly</span><span>Eagleyez</span><span>nova</span><span>Arise</span><span>SKYY</span><span>Zatrox</span><span>3mi</span><span>Kn1fed</span>
                </div>
              </div>
            </div>
            <div class="absolute inset-x-0 bottom-0 z-20 h-1 origin-left scale-x-0 bg-[#8624E5] transition duration-300 group-hover:scale-x-100"></div>
          </div>
        </div>
      </a>
      <a class="group block" href="/teams/valorant-gc">
        <div data-reveal data-reveal-delay="200" class="relative overflow-hidden border border-white/10 bg-black hover-tilt hover-glow">
          <div class="relative">
            <img src="/assets/images/game-valorant.jpg" alt="Valorant" class="h-auto w-full object-cover" style="aspect-ratio:900/1200" />
            <div class="absolute inset-0 bg-black/35 transition duration-300 group-hover:bg-black/60"></div>
            <div class="absolute inset-0 z-20 flex flex-col items-center justify-center px-6 text-center">
              <div class="transition-all duration-300 group-hover:-translate-y-6">
                <span class="text-3xl font-black uppercase tracking-[0.1em] text-white/80">VALORANT GC</span>
              </div>
              <div class="mt-6 translate-y-6 opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">
                <div class="flex flex-wrap items-center justify-center gap-x-2 gap-y-1 text-sm font-semibold text-white/90">
                  <span>Lina</span><span>AirFryer</span><span>Teddy</span><span>Dido</span><span>Aavatunchi</span><span>Kn1fed</span>
                </div>
              </div>
            </div>
            <div class="absolute inset-x-0 bottom-0 z-20 h-1 origin-left scale-x-0 bg-[#8624E5] transition duration-300 group-hover:scale-x-100"></div>
          </div>
        </div>
      </a>
      <a class="group block" href="/teams/league-of-legends">
        <div data-reveal data-reveal-delay="300" class="relative overflow-hidden border border-white/10 bg-black hover-tilt hover-glow">
          <div class="relative">
            <img src="/assets/images/game-lol.jpg" alt="League of Legends" class="h-auto w-full object-cover" style="aspect-ratio:900/1200" />
            <div class="absolute inset-0 bg-black/35 transition duration-300 group-hover:bg-black/60"></div>
            <div class="absolute inset-0 z-20 flex flex-col items-center justify-center px-6 text-center">
              <div class="transition-all duration-300 group-hover:-translate-y-6">
                <span class="text-3xl font-black uppercase tracking-[0.1em] text-white/80">LEAGUE OF LEGENDS</span>
              </div>
              <div class="mt-6 translate-y-6 opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">
                <div class="flex flex-wrap items-center justify-center gap-x-2 gap-y-1 text-sm font-semibold text-white/90">
                  <span>DROLET</span><span>Inoks</span><span>Frunkie</span><span>Dark</span><span>Akazan</span>
                </div>
              </div>
            </div>
            <div class="absolute inset-x-0 bottom-0 z-20 h-1 origin-left scale-x-0 bg-[#8624E5] transition duration-300 group-hover:scale-x-100"></div>
          </div>
        </div>
      </a>
      <a class="group block" href="/teams/mlbb">
        <div data-reveal data-reveal-delay="400" class="relative overflow-hidden border border-white/10 bg-black hover-tilt hover-glow">
          <div class="relative">
            <img src="/assets/images/game-mlbb.jpg" alt="MLBB" class="h-auto w-full object-cover" style="aspect-ratio:900/1200" />
            <div class="absolute inset-0 bg-black/35 transition duration-300 group-hover:bg-black/60"></div>
            <div class="absolute inset-0 z-20 flex flex-col items-center justify-center px-6 text-center">
              <div class="transition-all duration-300 group-hover:-translate-y-6">
                <span class="text-3xl font-black uppercase tracking-[0.1em] text-white/80">MLBB FEMALE</span>
              </div>
              <div class="mt-6 translate-y-6 opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">
                <div class="flex flex-wrap items-center justify-center gap-x-2 gap-y-1 text-sm font-semibold text-white/90">
                  <span>Axel</span><span>Heedo</span><span>Juvia</span><span>Lola</span><span>Skyvi</span><span>Sylvia</span><span>Lev</span>
                </div>
              </div>
            </div>
            <div class="absolute inset-x-0 bottom-0 z-20 h-1 origin-left scale-x-0 bg-[#8624E5] transition duration-300 group-hover:scale-x-100"></div>
          </div>
        </div>
      </a>
    </div>
  </section>

</Layout>
