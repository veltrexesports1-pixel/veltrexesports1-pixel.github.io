---
import Layout from '../layouts/Layout.astro';
---

<Layout title="VeltRex Esports Achievements" description="Our journey — VeltRex Esports is building Morocco's next generation of competitive talent.">

  <section class="border-b border-white/10 px-6 py-16 lg:px-12">
    <div class="mx-auto max-w-7xl text-center">
      <p class="mb-3 text-sm uppercase tracking-[0.3em] text-brand">trophy case</p>
      <h1 class="font-heading text-4xl font-black uppercase sm:text-6xl text-balance">Achievements</h1>
      <p class="mx-auto mt-5 max-w-3xl text-white/65">Milestones and competitive results across all VeltRex rosters.</p>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-6 py-20 lg:px-12">
    <div class="text-center">
      <div class="mb-8 inline-flex h-20 w-20 items-center justify-center rounded-full border border-white/10 bg-white/[0.03]">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#8624E5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C5 4 6 3 6 3s1 1 1.5 1a2.5 2.5 0 0 1 0 5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5C18 4 17 3 17 3s-1 1-1.5 1a2.5 2.5 0 0 0 0 5H18"/><path d="M4 22h16"/><path d="M10 22V2h4v20"/></svg>
      </div>
      <h2 class="font-heading text-3xl font-black uppercase text-balance"><span class="text-[#8624E5]">Our</span> <span class="text-stroke-sm text-white">Journey</span> <span class="text-stroke-sm text-white">Begins</span></h2>
      <p class="mx-auto mt-4 max-w-xl text-sm leading-7 text-white/60 sm:text-base">VeltRex Esports was founded to build Morocco's next generation of competitive talent. We're currently scrimming, bootcamping, and preparing for upcoming qualifiers.</p>
      <div class="mx-auto mt-10 grid max-w-2xl gap-4 sm:grid-cols-3">
        <div class="border border-white/10 bg-white/[0.03] p-6"><p class="font-heading text-3xl font-black text-[#8624E5]">1</p><p class="mt-2 text-xs uppercase tracking-wider text-white/50">Month Old</p></div>
        <div class="border border-white/10 bg-white/[0.03] p-6"><p class="font-heading text-3xl font-black text-[#8624E5]">4</p><p class="mt-2 text-xs uppercase tracking-wider text-white/50">Competitive Teams</p></div>
        <div class="border border-white/10 bg-white/[0.03] p-6"><p class="font-heading text-3xl font-black text-[#8624E5]">—</p><p class="mt-2 text-xs uppercase tracking-wider text-white/50">Trophies — Yet</p></div>
      </div>
      <p class="mt-10 text-sm text-white/50">Achievements will appear here as we compete. Stay connected.</p>
    </div>
  </section>

</Layout>
