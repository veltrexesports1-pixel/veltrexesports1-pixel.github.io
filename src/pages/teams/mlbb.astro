---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="VeltRex MLBB Female Roster" description="VeltRex Esports MLBB Female roster — Mobile Legends competitive team.">

  <section class="relative overflow-hidden border-b border-white/10">
    <img src="/assets/images/mlbb-hero.jpg" alt="" class="absolute inset-0 h-full w-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/60 to-black/90"></div>
    <div class="relative z-10 mx-auto max-w-7xl px-6 py-20 lg:px-12 lg:py-28">
      <div class="text-center">
        <p class="mb-3 text-sm uppercase tracking-[0.3em] text-[#8624E5]">roster</p>
        <h1 class="font-heading text-4xl font-black uppercase sm:text-6xl text-balance"><span class="text-[#8624E5]">MLBB</span> <span class="text-stroke-sm text-white">FEMALE</span></h1>
        <p class="mx-auto mt-5 max-w-3xl text-white/65">VeltRex Mobile Legends Bang Bang Female roster.</p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-6 py-20 lg:px-12">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <div class="border border-white/10 bg-white/[0.03] p-6 text-center"><h3 class="font-black uppercase">Axel</h3></div>
      <div class="border border-white/10 bg-white/[0.03] p-6 text-center"><h3 class="font-black uppercase">Heedo</h3></div>
      <div class="border border-white/10 bg-white/[0.03] p-6 text-center"><h3 class="font-black uppercase">Juvia</h3></div>
      <div class="border border-white/10 bg-white/[0.03] p-6 text-center"><h3 class="font-black uppercase">Lola</h3></div>
      <div class="border border-white/10 bg-white/[0.03] p-6 text-center"><h3 class="font-black uppercase">Skyvi</h3></div>
      <div class="border border-white/10 bg-white/[0.03] p-6 text-center"><h3 class="font-black uppercase">Sylvia</h3></div>
      <div class="border border-white/10 bg-white/[0.03] p-6 text-center"><h3 class="font-black uppercase">Lev</h3></div>
    </div>
  </section>

</Layout>
