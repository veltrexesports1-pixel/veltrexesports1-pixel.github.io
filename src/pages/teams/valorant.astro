---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="VeltRex Valorant Roster" description="VeltRex Esports Valorant competitive roster — tactical discipline and Moroccan talent.">

  <section class="relative overflow-hidden border-b border-white/10">
    <img src="/assets/images/valorant-hero.jpg" alt="" class="absolute inset-0 h-full w-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/60 to-black/90"></div>
    <div class="relative z-10 mx-auto max-w-7xl px-6 py-20 lg:px-12 lg:py-28">
      <div class="text-center">
        <p class="mb-3 text-sm uppercase tracking-[0.3em] text-[#8624E5]">roster</p>
        <h1 class="font-heading text-4xl font-black uppercase sm:text-6xl text-balance"><span class="text-[#8624E5]">VALORANT</span></h1>
        <p class="mx-auto mt-5 max-w-3xl text-white/65">VeltRex main Valorant roster.</p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-6 py-20 lg:px-12">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <div class="border border-white/10 bg-white/[0.03] p-6 text-center"><h3 class="font-black uppercase">Nelly</h3></div>
      <div class="border border-white/10 bg-white/[0.03] p-6 text-center"><h3 class="font-black uppercase">Eagleyez</h3></div>
      <div class="border border-white/10 bg-white/[0.03] p-6 text-center"><h3 class="font-black uppercase">nova</h3></div>
      <div class="border border-white/10 bg-white/[0.03] p-6 text-center"><h3 class="font-black uppercase">Arise</h3></div>
      <div class="border border-white/10 bg-white/[0.03] p-6 text-center"><h3 class="font-black uppercase">SKYY</h3></div>
      <div class="border border-white/10 bg-white/[0.03] p-6 text-center"><h3 class="font-black uppercase">Zatrox</h3></div>
      <div class="border border-white/10 bg-white/[0.03] p-6 text-center"><h3 class="font-black uppercase">3mi</h3></div>
      <div class="border border-white/10 bg-white/[0.03] p-6 text-center"><h3 class="font-black uppercase">Kn1fed</h3></div>
    </div>
  </section>

</Layout>
