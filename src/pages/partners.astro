---
import Layout from '../layouts/Layout.astro';
---

<Layout title="VeltRex Esports Partners | GeroZone & More" description="Meet GeroZone, VeltRex Esports' official tournament platform partner. Learn about partnership opportunities and how to collaborate.">

  <section class="relative overflow-hidden border-b border-white/10 px-4 py-14 sm:px-6 lg:px-12 lg:py-24">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(134,36,229,0.12),transparent_40%)]"></div>
    <div class="mx-auto max-w-7xl relative">
      <p class="mb-4 text-xs uppercase tracking-[0.3em] text-[#8624E5] sm:text-sm">Our Partners</p>
      <h1 class="font-heading text-4xl font-black uppercase leading-[0.92] sm:text-6xl lg:text-7xl text-balance">Powered By <span class="text-[#8624E5]">Partnership</span></h1>
      <p class="mt-6 max-w-2xl text-sm leading-7 text-white/70 sm:text-base sm:leading-8">We collaborate with brands and platforms that share our vision for competitive gaming, creator growth, and community culture.</p>
    </div>
  </section>

  <section class="px-4 py-12 sm:px-6 lg:px-12 lg:py-16">
    <div class="mx-auto max-w-7xl">
      <h2 class="font-heading text-3xl font-black uppercase sm:text-4xl text-balance">
        <span class="text-[#8624E5]">Featured</span> <span class="text-stroke-sm text-white">Partner</span>
      </h2>
      <div class="mt-10 grid gap-10 lg:grid-cols-[1.2fr_0.8fr] items-center border border-white/10 bg-[linear-gradient(135deg,rgba(134,36,229,0.06)_0%,rgba(255,255,255,0.015)_50%)] p-6 sm:p-10 lg:p-14">
        <div>
          <div class="flex items-center gap-4">
            <img src="https://play.gerozone.gg/LogoGerozone.svg" alt="GeroZone" class="h-10 sm:h-12" onerror="this.style.display='none'" />
            <span class="text-xs font-bold uppercase tracking-[0.22em] text-[#8624E5]">Esports Platform</span>
          </div>
          <h3 class="mt-6 font-heading text-3xl font-black uppercase sm:text-4xl">GeroZone</h3>
          <p class="mt-4 text-sm leading-7 text-white/75 sm:text-base sm:leading-8">GeroZone is a competitive esports platform offering curated tournaments, pro team discovery, and content creator showcases. It supports 8 active game titles including Valorant, League of Legends, EA FC, CS2, Fortnite, Apex, Free Fire, and eFootball — crafting the next generation of competitive gaming.</p>
          <div class="mt-6 flex flex-wrap gap-6 text-xs uppercase tracking-[0.18em] text-white/50">
            <span class="flex items-center gap-2">
              <svg class="text-[#8624E5]" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
              8 Games
            </span>
            <span class="flex items-center gap-2">
              <svg class="text-[#8624E5]" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
              Tournaments
            </span>
            <span class="flex items-center gap-2">
              <svg class="text-[#8624E5]" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
              Creator Showcases
            </span>
          </div>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="https://play.gerozone.gg/" target="_blank" rel="noreferrer" class="inline-flex items-center justify-center gap-2 border border-[#8624E5] bg-[#8624E5] px-6 py-4 text-xs font-bold uppercase tracking-[0.2em] text-white transition hover:bg-transparent hover:text-[#8624E5]">
              Visit GeroZone
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
            </a>
            <a href="https://www.instagram.com/gerozone.gg/" target="_blank" rel="noreferrer" class="inline-flex items-center justify-center gap-2 border border-white/10 bg-white/[0.03] px-6 py-4 text-xs font-bold uppercase tracking-[0.2em] text-white/80 transition hover:border-[#8624E5]/40 hover:text-[#8624E5]">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg>
              Instagram
            </a>
          </div>
        </div>
        <div class="relative aspect-[16/9] w-full overflow-hidden border border-white/10">
          <img src="https://play.gerozone.gg/assets/home/gerozone-banner.jpg" alt="GeroZone banner" class="h-full w-full object-cover" onerror="this.style.display='none'" />
          <div class="absolute inset-0 bg-gradient-to-t from-[#070809] via-transparent to-transparent"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-white/10 px-4 py-12 sm:px-6 lg:px-12 lg:py-16">
    <div class="mx-auto max-w-7xl">
      <h2 class="font-heading text-3xl font-black uppercase sm:text-4xl text-balance">
        <span class="text-[#8624E5]">Our</span> <span class="text-stroke-sm text-white">Partners</span>
      </h2>
      <p class="mt-4 text-sm leading-7 text-white/70 sm:text-base sm:leading-8">The brands and platforms that power VeltRex Esports.</p>
      <div class="mt-10 grid grid-cols-2 gap-x-8 gap-y-10 sm:grid-cols-3 lg:grid-cols-6">
        <div class="flex min-h-[90px] items-center justify-center border border-white/5 bg-white/[0.02] px-4 py-6 transition duration-300 hover:-translate-y-1 hover:border-[#8624E5]/25 hover:bg-white/[0.04]">
          <span class="font-black uppercase tracking-[0.1em] text-white/40 text-sm text-center">Qasbah Labs</span>
        </div>
        <div class="flex min-h-[90px] items-center justify-center border border-white/5 bg-white/[0.02] px-4 py-6 transition duration-300 hover:-translate-y-1 hover:border-[#8624E5]/25 hover:bg-white/[0.04]">
          <span class="font-black uppercase tracking-[0.1em] text-white/40 text-sm text-center">PlayerZ Maroc</span>
        </div>
        <div class="flex min-h-[90px] items-center justify-center border border-white/5 bg-white/[0.02] px-4 py-6 transition duration-300 hover:-translate-y-1 hover:border-[#8624E5]/25 hover:bg-white/[0.04]">
          <span class="font-black uppercase tracking-[0.1em] text-white/40 text-sm text-center">KingSpec</span>
        </div>
        <div class="flex min-h-[90px] items-center justify-center border border-white/5 bg-white/[0.02] px-4 py-6 transition duration-300 hover:-translate-y-1 hover:border-[#8624E5]/25 hover:bg-white/[0.04]">
          <span class="font-black uppercase tracking-[0.1em] text-white/40 text-sm text-center">ATK Gear</span>
        </div>
        <div class="flex min-h-[90px] items-center justify-center border border-white/5 bg-white/[0.02] px-4 py-6 transition duration-300 hover:-translate-y-1 hover:border-[#8624E5]/25 hover:bg-white/[0.04]">
          <span class="font-black uppercase tracking-[0.1em] text-white/40 text-sm text-center">GKOI</span>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-white/10 px-4 py-12 sm:px-6 lg:px-12 lg:py-16">
    <div class="mx-auto max-w-7xl">
      <h2 class="font-heading text-3xl font-black uppercase sm:text-4xl text-balance">
        <span class="text-[#8624E5]">Why Partner</span> <span class="text-stroke-sm text-white">With Us</span>
      </h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="border border-white/10 bg-white/[0.03] p-6 sm:p-8 transition hover:border-[#8624E5]/30">
          <div class="flex h-12 w-12 items-center justify-center border border-[#8624E5]/30 bg-[#8624E5]/10">
            <svg class="text-[#8624E5]" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          </div>
          <h3 class="mt-5 font-heading text-xl font-black uppercase">Community Reach</h3>
          <p class="mt-3 text-sm leading-7 text-white/70">Access a growing community of competitive gamers, content creators, and esports fans across Morocco and beyond.</p>
        </div>
        <div class="border border-white/10 bg-white/[0.03] p-6 sm:p-8 transition hover:border-[#8624E5]/30">
          <div class="flex h-12 w-12 items-center justify-center border border-[#8624E5]/30 bg-[#8624E5]/10">
            <svg class="text-[#8624E5]" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
          </div>
          <h3 class="mt-5 font-heading text-xl font-black uppercase">Brand Visibility</h3>
          <p class="mt-3 text-sm leading-7 text-white/70">Showcase your brand across our website, social channels, live streams, and tournament broadcasts.</p>
        </div>
        <div class="border border-white/10 bg-white/[0.03] p-6 sm:p-8 transition hover:border-[#8624E5]/30">
          <div class="flex h-12 w-12 items-center justify-center border border-[#8624E5]/30 bg-[#8624E5]/10">
            <svg class="text-[#8624E5]" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
          </div>
          <h3 class="mt-5 font-heading text-xl font-black uppercase">Creator Activations</h3>
          <p class="mt-3 text-sm leading-7 text-white/70">Partner with our roster of creators for sponsored content, product placements, and co-branded campaigns.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-white/10 px-4 py-12 sm:px-6 lg:px-12 lg:py-16">
    <div class="mx-auto max-w-7xl">
      <h2 class="font-heading text-3xl font-black uppercase sm:text-4xl text-balance">
        <span class="text-[#8624E5]">How To</span> <span class="text-stroke-sm text-white">Apply</span>
      </h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <div class="text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full border border-[#8624E5]/30 bg-[#8624E5]/10 text-2xl font-black text-[#8624E5]">1</div>
          <h3 class="mt-5 font-heading text-lg font-black uppercase">Submit Form</h3>
          <p class="mt-2 text-sm leading-7 text-white/65">Fill out the inquiry form below with your brand details and partnership interest.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full border border-[#8624E5]/30 bg-[#8624E5]/10 text-2xl font-black text-[#8624E5]">2</div>
          <h3 class="mt-5 font-heading text-lg font-black uppercase">Review Call</h3>
          <p class="mt-2 text-sm leading-7 text-white/65">Our partnerships team reviews your submission and schedules a discovery call.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full border border-[#8624E5]/30 bg-[#8624E5]/10 text-2xl font-black text-[#8624E5]">3</div>
          <h3 class="mt-5 font-heading text-lg font-black uppercase">Proposal</h3>
          <p class="mt-2 text-sm leading-7 text-white/65">We present a tailored partnership proposal aligned with your brand goals.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full border border-[#8624E5]/30 bg-[#8624E5]/10 text-2xl font-black text-[#8624E5]">4</div>
          <h3 class="mt-5 font-heading text-lg font-black uppercase">Launch</h3>
          <p class="mt-2 text-sm leading-7 text-white/65">Once agreed, we onboard and activate the partnership across our ecosystem.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="partner-form" class="border-t border-white/10 px-4 py-12 sm:px-6 lg:px-12 lg:py-16">
    <div class="mx-auto max-w-3xl">
      <h2 class="font-heading text-3xl font-black uppercase sm:text-4xl text-balance">
        <span class="text-[#8624E5]">Partner</span> <span class="text-stroke-sm text-white">Inquiry</span>
      </h2>
      <p class="mt-4 text-sm leading-7 text-white/70 sm:text-base sm:leading-8">Interested in partnering with VeltRex Esports? Fill out the form below and we'll get back to you.</p>
      <form action="https://formsubmit.co/veltrexesports1@gmail.com" method="POST" class="mt-8 space-y-5">
        <input type="hidden" name="_subject" value="New Partnership Inquiry" />
        <input type="hidden" name="_next" value="https://veltrexesports1-pixel.github.io/partners" />
        <input type="hidden" name="_captcha" value="true" />
        <input type="text" name="_honey" style="display:none" />
        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <label class="mb-3 block text-xs font-bold uppercase tracking-[0.18em] text-white/70">Brand / Company Name *</label>
            <input type="text" name="brand_name" required class="w-full border border-white/10 bg-black px-4 py-4 text-white outline-none placeholder:text-white/30" placeholder="Your Brand" />
          </div>
          <div>
            <label class="mb-3 block text-xs font-bold uppercase tracking-[0.18em] text-white/70">Contact Name *</label>
            <input type="text" name="contact_name" required class="w-full border border-white/10 bg-black px-4 py-4 text-white outline-none placeholder:text-white/30" placeholder="Full Name" />
          </div>
        </div>
        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <label class="mb-3 block text-xs font-bold uppercase tracking-[0.18em] text-white/70">Email Address *</label>
            <input type="email" name="email" required class="w-full border border-white/10 bg-black px-4 py-4 text-white outline-none placeholder:text-white/30" placeholder="you@example.com" />
          </div>
          <div>
            <label class="mb-3 block text-xs font-bold uppercase tracking-[0.18em] text-white/70">Website URL</label>
            <input type="url" name="website" class="w-full border border-white/10 bg-black px-4 py-4 text-white outline-none placeholder:text-white/30" placeholder="https://..." />
          </div>
        </div>
        <div>
          <label class="mb-3 block text-xs font-bold uppercase tracking-[0.18em] text-white/70">Partnership Category *</label>
          <select name="category" required class="w-full border border-white/10 bg-black px-4 py-4 text-white outline-none">
            <option value="">Select a category...</option>
            <option>Sponsorship</option>
            <option>Tournament / Platform Partner</option>
            <option>Content / Creator Collaboration</option>
            <option>Event Co-Hosting</option>
            <option>Technology / Service Provider</option>
            <option>Media / Press</option>
            <option>Other</option>
          </select>
        </div>
        <div>
          <label class="mb-3 block text-xs font-bold uppercase tracking-[0.18em] text-white/70">Tell Us About Your Brand *</label>
          <textarea rows="5" name="brand_description" required class="w-full border border-white/10 bg-black px-4 py-4 text-white outline-none placeholder:text-white/30" placeholder="Describe your brand, what you do, and why you're interested in partnering with VeltRex Esports."></textarea>
        </div>
        <div>
          <label class="mb-3 block text-xs font-bold uppercase tracking-[0.18em] text-white/70">Proposed Partnership Idea</label>
          <textarea rows="4" name="partnership_idea" class="w-full border border-white/10 bg-black px-4 py-4 text-white outline-none placeholder:text-white/30" placeholder="Any specific ideas or collaboration models you have in mind?"></textarea>
        </div>
        <div class="border border-white/10 bg-black/40 p-4">
          <p class="text-xs uppercase tracking-[0.18em] text-white/60">Data Processing Consent</p>
          <label class="mt-3 flex items-start gap-3 text-sm leading-6 text-white/70">
            <input type="checkbox" name="consent" value="agreed" required class="mt-1" />
            <span>By sending this form, you agree with the storage and handling of your information for partnership evaluation purposes.</span>
          </label>
        </div>
        <button type="submit" class="inline-flex items-center justify-center gap-2 border border-[#8624E5] bg-[#8624E5] px-6 py-4 text-xs font-bold uppercase tracking-[0.2em] text-white transition hover:bg-transparent hover:text-[#8624E5] disabled:cursor-not-allowed disabled:opacity-60">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          Send Inquiry
        </button>
      </form>
    </div>
  </section>

</Layout>
